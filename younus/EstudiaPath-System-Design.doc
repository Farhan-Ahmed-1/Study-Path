<title>Prime' New Generation — System Design</title>
<!--[if gte mso 9]><xml><w:WordDocument><w:View>Print</w:View><w:Zoom>100</w:Zoom></w:WordDocument></xml><![endif]-->
<style>
 body{font-family:'Calibri',sans-serif;font-size:11pt;color:#1a1a1a;line-height:1.5;}
 h1{font-size:24pt;color:#02122b;border-bottom:3px solid #3b6fff;padding-bottom:6px;}
 h2{font-size:17pt;color:#02122b;margin-top:24px;border-bottom:1px solid #ccc;padding-bottom:3px;}
 h3{font-size:13pt;color:#3b6fff;margin-top:16px;}
 table{border-collapse:collapse;width:100%;margin:10px 0;}
 th{background:#02122b;color:#fff;text-align:left;padding:6px 8px;font-size:10pt;}
 td{border:1px solid #cccccc;padding:6px 8px;font-size:10pt;vertical-align:top;}
 tr:nth-child(even) td{background:#f4f7ff;}
 pre{background:#0f1b33;color:#d6e2ff;padding:12px;font-family:'Consolas',monospace;font-size:9pt;white-space:pre;}
 code{background:#eef2ff;color:#1a3a8f;font-family:'Consolas',monospace;font-size:9.5pt;padding:1px 3px;}
 .lead{background:#eef2ff;border-left:4px solid #3b6fff;padding:10px 14px;font-style:italic;}
 ul{margin:6px 0 6px 0;}
 li{margin:3px 0;}
